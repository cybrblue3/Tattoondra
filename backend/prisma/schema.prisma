// Tattoondra Database Schema
// Generated: 2026-02-22

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN
  ARTIST
  RECEPTIONIST
  CLIENT
}

enum AppointmentStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentType {
  CASH
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
}

// ============================================
// MODELS
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique // Keep as required in schema for now
  password  String
  name      String
  phone     String?  // Keep as optional in schema for now
  role      UserRole @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Google Calendar OAuth tokens
  googleAccessToken  String? // Short-lived token for API calls
  googleRefreshToken String? // Long-lived token for refreshing access
  googleTokenExpiry  DateTime? // When access token expires

  // Relations
  clientAppointments Appointment[] @relation("ClientAppointments")
  artistAppointments Appointment[] @relation("ArtistAppointments")
  payments           Payment[]
  // sessions           Session[] // Uncomment for post-MVP session tracking
}

model Appointment {
  id              String            @id @default(cuid())
  date            DateTime
  duration        Int               @default(60) // minutes
  description     String?
  status          AppointmentStatus @default(PENDING_CONFIRMATION)
  depositAmount   Decimal           @default(200.00)
  depositReceived Boolean           @default(false)
  totalPrice      Decimal?
  consentSigned   Boolean           @default(false)
  consentSignedAt DateTime?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Google Calendar Integration
  googleCalendarEventId String? // Store Google Calendar event ID for sync

  // Relations
  clientId      String
  client        User            @relation("ClientAppointments", fields: [clientId], references: [id])
  artistId      String?
  artist        User?           @relation("ArtistAppointments", fields: [artistId], references: [id])
  payments      Payment[]
  materialsUsed MaterialUsage[] // Track materials used per appointment

  @@index([date])
  @@index([clientId])
  @@index([status])
}

model Payment {
  id        String        @id @default(cuid())
  amount    Decimal
  type      PaymentType
  status    PaymentStatus @default(COMPLETED)
  isDeposit Boolean       @default(false)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  receivedById  String
  receivedBy    User        @relation(fields: [receivedById], references: [id])

  @@index([appointmentId])
  @@index([createdAt])
}

